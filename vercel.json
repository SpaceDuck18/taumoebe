{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "server/server.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "server/server.js"
    },
    {
      "source": "/auth/(.*)",
      "destination": "server/server.js"
    },
    {
      "source": "/batches/(.*)",
      "destination": "server/server.js"
    },
    {
      "source": "/health",
      "destination": "server/server.js"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "server/server.js"
    }
  ]
}
